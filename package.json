{
  "name": "@resolid/wechat",
  "version": "0.0.2",
  "description": "Modern WeChat SDK for Node.js.",
  "keywords": [
    "nodejs",
    "resolid",
    "typescript",
    "wechat"
  ],
  "homepage": "https://www.resolid.tech",
  "license": "MIT",
  "author": "Huijie Wei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resolid/wechat.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "changeset": "changeset",
    "build": "tsdown",
    "format": "oxfmt",
    "lint": "oxlint",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project integration",
    "typecheck": "tsc --noEmit",
    "serve": "srvx serve --import=jiti/register --entry ./servers/official-account-server.ts"
  },
  "dependencies": {
    "@resolid/cache": "^1.3.0",
    "@resolid/utils": "^1.7.1",
    "fast-xml-builder": "^1.3.0",
    "fast-xml-parser": "^5.10.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@resolid/config": "^6.1.0",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jiti": "^2.7.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": "^7.0.2001",
    "srvx": "^0.12.1",
    "tsdown": "^0.22.13",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "^22.22.0 || >=24"
  },
  "packageManager": "pnpm@11.15.1"
}
