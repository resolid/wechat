{
  "name": "@resolid/wechat",
  "version": "0.0.1",
  "description": "Modern WeChat SDK for Node.js.",
  "keywords": [
    "nodejs",
    "resolid",
    "typescript",
    "wechat"
  ],
  "homepage": "https://www.resolid.tech",
  "license": "MIT",
  "author": "Huijie Wei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resolid/wechat.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "changeset": "changeset",
    "build": "tsdown",
    "format": "oxfmt",
    "lint": "oxlint",
    "test": "vitest run --project unit",
    "test:e2e": "vitest run --project integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@resolid/cache": "^1.2.1",
    "@resolid/utils": "^1.6.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@resolid/config": "^5.3.22",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.8",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "packageManager": "pnpm@11.5.1"
}
